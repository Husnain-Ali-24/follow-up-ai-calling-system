APP_NAME=Outbound AI Calling API
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=change-this-secret-key-in-production-please
ACCESS_TOKEN_EXPIRE_MINUTES=60
DATABASE_URL=sqlite:///./data/app.db
BACKEND_CORS_ORIGINS=http://localhost:8000,http://localhost:5173
DEFAULT_PHONE_REGION=US
BASE_URL=http://localhost:8000

VAPI_API_KEY=
VAPI_BASE_URL=https://api.vapi.ai
VAPI_PHONE_NUMBER_ID=
VAPI_ASSISTANT_ID=
VAPI_WEBHOOK_SECRET=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
CALLING_WINDOW_START=09:00
CALLING_WINDOW_END=20:00
MAX_CALL_RETRIES=3
RETRY_DELAY_1_MINUTES=30
RETRY_DELAY_2_MINUTES=120
RETRY_DELAY_3_HOURS=24
MAX_CONCURRENT_CALLS=10
SCHEDULER_ENABLED=false
SCHEDULER_TICK_SECONDS=30

DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_FULL_NAME=Admin User
