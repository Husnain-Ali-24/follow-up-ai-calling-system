APP_NAME=Outbound AI Calling API
APP_ENV=production
APP_DEBUG=false
API_V1_PREFIX=/api/v1
SECRET_KEY=replace-with-a-long-random-production-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
DATABASE_URL=postgresql+psycopg://postgres:replace-db-password@db:5432/outbound_ai_calling
BACKEND_CORS_ORIGINS=https://your-frontend-domain.com
DEFAULT_PHONE_REGION=US
BASE_URL=https://your-api-domain.com
POSTGRES_DB=outbound_ai_calling
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-db-password

VAPI_API_KEY=
VAPI_BASE_URL=https://api.vapi.ai
VAPI_PHONE_NUMBER_ID=
VAPI_ASSISTANT_ID=
VAPI_WEBHOOK_SECRET=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
CALLING_WINDOW_START=09:00
CALLING_WINDOW_END=17:00
MAX_CALL_RETRIES=3
RETRY_DELAY_1_MINUTES=30
RETRY_DELAY_2_MINUTES=120
RETRY_DELAY_3_HOURS=24
MAX_CONCURRENT_CALLS=10
SCHEDULER_ENABLED=true
SCHEDULER_TICK_SECONDS=30

DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=replace-admin-password
DEFAULT_ADMIN_FULL_NAME=Admin User
